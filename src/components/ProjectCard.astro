---
import type { Project } from '../data/projects';

interface Props {
  project: Project;
}

const { project } = Astro.props;

const iconMap: Record<string, string> = {
  paper: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z',
  code: 'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4',
  demo: 'M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z',
  video: 'M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
  website: 'M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9',
};
---

<article class="project-card">
  <div class="card-body">
    <div class="card-header">
      <span class="card-year">{project.year}</span>
      <a href={`/projects/${project.slug}`} class="card-title-link">
        <h3 class="card-title">{project.title}</h3>
      </a>
    </div>
    <p class="card-description">{project.description}</p>

    <div class="card-tags">
      {project.tags.slice(0, 4).map((tag) => (
        <span class="card-tag">{tag}</span>
      ))}
    </div>

    <div class="card-links">
      {project.links.map((link) => (
        <a
          href={link.url}
          class="card-link-btn"
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`${link.label ?? link.type} for ${project.title}`}
        >
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d={iconMap[link.type] ?? iconMap.website} />
          </svg>
          {link.label ?? link.type}
        </a>
      ))}
      <a href={`/projects/${project.slug}`} class="card-link-btn card-link-primary">
        Details →
      </a>
    </div>
  </div>
</article>

<style>
  .project-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 8px;
    box-shadow: var(--card-shadow);
    transition: box-shadow 0.2s ease, transform 0.2s ease;
    display: flex;
    flex-direction: column;
  }

  .project-card:hover {
    box-shadow: var(--card-shadow-hover);
    transform: translateY(-1px);
  }

  .card-body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    flex: 1;
  }

  .card-header {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .card-year {
    font-size: 0.75rem;
    font-weight: 500;
    font-family: var(--font-mono);
    color: var(--text-muted);
  }

  .card-title-link {
    text-decoration: none;
  }

  .card-title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1.35;
    letter-spacing: -0.02em;
    margin: 0;
  }

  .card-title-link:hover .card-title {
    opacity: 0.7;
  }

  .card-description {
    font-size: 0.85rem;
    color: var(--text-secondary);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin: 0;
    flex: 1;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .card-tag {
    font-size: 0.72rem;
    font-weight: 400;
    color: var(--text-muted);
  }

  .card-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--border-subtle);
    margin-top: auto;
  }

  .card-link-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.25rem 0.6rem;
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--text-muted);
    border: 1px solid var(--border);
    text-decoration: none;
    transition: color 0.15s, border-color 0.15s;
  }

  .card-link-btn:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  .card-link-primary {
    color: var(--accent);
    border-color: color-mix(in srgb, var(--accent) 30%, transparent);
    margin-left: auto;
  }
</style>
