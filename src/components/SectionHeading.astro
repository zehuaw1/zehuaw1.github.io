---
interface Props {
  title: string;
  subtitle?: string;
  align?: 'left' | 'center';
  class?: string;
}

const { title, subtitle, align = 'left', class: className = '' } = Astro.props;
---

<div class={`section-heading ${align === 'center' ? 'heading-center' : ''} ${className}`}>
  <h2 class="heading-title">{title}</h2>
  {subtitle && <p class="heading-subtitle">{subtitle}</p>}
</div>

<style>
  .section-heading {
    margin-bottom: 3rem;
  }

  .heading-center {
    text-align: center;
  }

  .heading-title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    color: var(--text-primary);
    letter-spacing: -0.03em;
    margin-bottom: 0.5rem;
    display: inline-block;
    border-bottom: 2px solid var(--accent);
    padding-bottom: 0.25rem;
  }

  .heading-subtitle {
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.6;
    max-width: 56ch;
    margin-top: 0.25rem;
  }

  .heading-center .heading-subtitle {
    margin-left: auto;
    margin-right: auto;
  }
</style>
