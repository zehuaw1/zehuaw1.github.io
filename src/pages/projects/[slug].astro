---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Badge from '../../components/Badge.astro';
import ScrollFadeIn from '../../components/ScrollFadeIn.tsx';
import projects from '../../data/projects';
import type { Project } from '../../data/projects';

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

interface Props {
  project: Project;
}

const { project } = Astro.props;

const iconMap: Record<string, string> = {
  paper: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z',
  code: 'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4',
  demo: 'M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z',
  video: 'M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
  website: 'M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9',
};
---

<BaseLayout title={project.title} description={project.description}>
  <section class="section">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/projects">← Projects</a>
      </nav>

      <ScrollFadeIn client:visible>
        <div class="project-header">
          <div class="project-meta">
            <span class="project-year">{project.year}</span>
            {project.featured && <span class="project-featured">Featured</span>}
          </div>
          <h1 class="project-title">{project.title}</h1>
          <p class="project-short-desc">{project.description}</p>

          <div class="project-links">
            {project.links.map((link) => (
              <a
                href={link.url}
                class="project-link-btn"
                target="_blank"
                rel="noopener noreferrer"
              >
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d={iconMap[link.type] ?? iconMap.website} />
                </svg>
                {link.label ?? link.type}
              </a>
            ))}
          </div>
        </div>
      </ScrollFadeIn>

      <ScrollFadeIn client:visible delay={0.1}>
        <div class="project-body">
          <div class="prose-content">
            {(project.longDescription || project.content || project.description).split('\n\n').map((paragraph) => (
              <p>{paragraph.trim()}</p>
            ))}
          </div>
        </div>
      </ScrollFadeIn>

      <ScrollFadeIn client:visible delay={0.15}>
        <div class="project-tags-section">
          <h2 class="tags-label">Technologies & Topics</h2>
          <div class="project-tags">
            {project.tags.map((tag) => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        </div>
      </ScrollFadeIn>
    </div>
  </section>
</BaseLayout>

<style>
  .container {
    max-width: 48rem;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .breadcrumb {
    margin-bottom: 2rem;
  }

  .breadcrumb a {
    font-size: 0.85rem;
    font-weight: 400;
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.15s;
  }

  .breadcrumb a:hover {
    color: var(--text-primary);
  }

  .project-header {
    margin-bottom: 3rem;
  }

  .project-meta {
    display: flex;
    gap: 0.75rem;
    margin-bottom: 1rem;
    align-items: center;
  }

  .project-year {
    font-size: 0.78rem;
    font-weight: 500;
    font-family: var(--font-mono);
    color: var(--text-muted);
  }

  .project-featured {
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--text-muted);
  }

  .project-title {
    font-size: clamp(1.6rem, 4vw, 2.2rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.15;
    margin-bottom: 1rem;
  }

  .project-short-desc {
    font-size: 1rem;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }

  .project-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .project-link-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.4rem 0.9rem;
    border-radius: 6px;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--text-muted);
    border: 1px solid var(--border);
    text-decoration: none;
    transition: color 0.15s, border-color 0.15s;
  }

  .project-link-btn:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  .project-body {
    padding-bottom: 2.5rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 2.5rem;
  }

  .project-tags-section {
    margin-bottom: 2rem;
  }

  .tags-label {
    font-size: 0.78rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    margin-bottom: 0.75rem;
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }
</style>
