#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/Users/zehuaw/dev/academic-folio/node_modules/vite/bin/node_modules:/Users/zehuaw/dev/academic-folio/node_modules/vite/node_modules:/Users/zehuaw/dev/academic-folio/node_modules:/Users/zehuaw/dev/node_modules:/Users/zehuaw/node_modules:/Users/node_modules:/node_modules:/Users/zehuaw/dev/academic-folio/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/Users/zehuaw/dev/academic-folio/node_modules/vite/bin/node_modules:/Users/zehuaw/dev/academic-folio/node_modules/vite/node_modules:/Users/zehuaw/dev/academic-folio/node_modules:/Users/zehuaw/dev/node_modules:/Users/zehuaw/node_modules:/Users/node_modules:/node_modules:/Users/zehuaw/dev/academic-folio/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../vite/bin/vite.js" "$@"
else
  exec node  "$basedir/../vite/bin/vite.js" "$@"
fi
